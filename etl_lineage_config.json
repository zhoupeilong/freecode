          "controls": "join_path",
          "description": "控制DW表的JOIN方式：=1走trust_manager(T2), =2走trust_manager+B+C(T4)",
          "values": {
            "1": {
              "dw_table": "DW_D_COMPANY_EMP_INFO",
              "dw_alias_in_etl": "T2",
              "join_condition": "ON INSTR(CONCAT(CONCAT(',', T.TRUST_MANAGER), ','),CONCAT(CONCAT(',', emp.EMPLOYEE_ID), ',')) > 0",
              "join_condition_sql": "inner join urp3_xtdw.dw_d_company_emp_info emp\n    on instr(concat(concat(',', proj.trust_manager), ','),concat(concat(',', emp.employee_id), ',')) > 0"
            },
            "2": {
              "dw_table": "DW_D_COMPANY_EMP_INFO",
              "dw_alias_in_etl": "T4",
              "join_condition": "ON INSTR(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(CONCAT(',', T.TRUST_MANAGER), ','),T.TRUST_MANAGER_B), ','),T.TRUST_MANAGER_C),','),CONCAT(CONCAT(',', T4.EMPLOYEE_ID), ',')) > 0",
              "join_condition_sql": "inner join urp3_xtdw.dw_d_company_emp_info emp\n    on instr(concat(concat(concat(concat(concat(concat(',', proj.trust_manager), ','),proj.trust_manager_b), ','),proj.trust_manager_c),','),concat(concat(',', emp.employee_id), ',')) > 0"
            }
          }
        },
